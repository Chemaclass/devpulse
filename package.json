{
  "name": "devpulse",
  "version": "0.1.0",
  "description": "Fun, futuristic GitHub work tracker. Type any username and see how much they worked each day, on which projects, and how many contributions (commits, PRs, issues, reviews). Public data only — no token required. Deployable to GitHub Pages.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "simple-git-hooks || true",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "report": "tsx src/cli/index.ts",
    "report:watch": "tsx watch src/cli/index.ts",
    "clean": "rm -rf dist out",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dead": "knip",
    "cycles": "madge --circular --extensions ts,tsx src/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "og:image": "\"${CHROME:-/Applications/Google Chrome.app/Contents/MacOS/Google Chrome}\" --headless=new --disable-gpu --hide-scrollbars --force-device-scale-factor=1 --window-size=1200,630 --screenshot=public/og-default.png \"file://$PWD/scripts/og-default.html\""
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.14.1",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "github",
    "stats",
    "contributions",
    "cli",
    "dashboard",
    "react",
    "vite",
    "github-pages"
  ],
  "author": "Chemaclass",
  "license": "MIT",
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "chart.js": "^4.4.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.29.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.9.6",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
