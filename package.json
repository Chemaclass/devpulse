{
  "name": "devpulse",
  "version": "0.1.0",
  "description": "Fun, futuristic GitHub work tracker. Type any username and see how much they worked each day, on which projects, and how many contributions (commits, PRs, issues, reviews). Public data only — no token required. Deployable to GitHub Pages.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "report": "tsx src/cli/index.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github",
    "stats",
    "contributions",
    "cli",
    "dashboard",
    "react",
    "vite",
    "github-pages"
  ],
  "author": "Chemaclass",
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
